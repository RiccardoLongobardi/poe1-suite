# --- PoE league ---
# Slug of the current league. Examples: "Settlers", "Necropolis", "Standard".
POE_LEAGUE=Standard

# --- poe.ninja ---
POE_NINJA_BASE_URL=https://poe.ninja/api/data

# --- GGG official APIs (optional) ---
# Only needed for authenticated trade API calls.
# Get it from pathofexile.com cookies (session).
POESESSID=

# --- LLM (optional, for FOB Intent Engine fallback) ---
ANTHROPIC_API_KEY=

# --- App runtime ---
LOG_LEVEL=INFO
CACHE_DIR=./.cache_http
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=3
